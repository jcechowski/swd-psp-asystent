<?xml version="1.0"?>
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Preload critical product image for LCP -->
        <attribute name="class" value="catalog-product-view"/>
    </head>
    <body>
        <!-- Ensure description tab is visible -->
        <referenceBlock name="product.info.description">
            <arguments>
                <argument name="title" translate="true" xsi:type="string">Opis</argument>
            </arguments>
        </referenceBlock>

        <!-- Ensure attributes tab is visible with Polish title -->
        <referenceBlock name="product.attributes">
            <arguments>
                <argument name="title" translate="true" xsi:type="string">Dane techniczne</argument>
            </arguments>
        </referenceBlock>

        <!-- Ensure reviews tab has Polish title -->
        <referenceBlock name="reviews.tab">
            <arguments>
                <argument name="title" translate="true" xsi:type="string">Opinie</argument>
            </arguments>
        </referenceBlock>

        <!-- GPSR tab (EU 2023/988 Product Safety) -->
        <referenceBlock name="product.info.details">
            <block class="Magento\Catalog\Block\Product\View"
                   name="product.info.gpsr"
                   template="Magento_Catalog::product/gpsr.phtml"
                   group="detailed_info">
                <arguments>
                    <argument name="title" translate="true" xsi:type="string">Bezpieczeństwo (GPSR)</argument>
                    <argument name="sort_order" xsi:type="string">40</argument>
                </arguments>
            </block>
        </referenceBlock>

        <!-- Brand/manufacturer logo -->
        <referenceContainer name="product.info.main">
            <block class="Magento\Catalog\Block\Product\View"
                   name="product.brand.logo"
                   template="Magento_Catalog::product/brand-logo.phtml"
                   before="-"/>
        </referenceContainer>

        <!-- Product JSON-LD structured data (Schema.org) -->
        <referenceContainer name="before.body.end">
            <block class="Magento\Catalog\Block\Product\View"
                   name="product.jsonld"
                   template="Magento_Catalog::product/jsonld.phtml"/>
        </referenceContainer>
    </body>
</page>
