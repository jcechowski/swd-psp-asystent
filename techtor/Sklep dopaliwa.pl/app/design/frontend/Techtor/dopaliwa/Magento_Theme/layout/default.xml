<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Logo -->
        <referenceBlock name="logo">
            <arguments>
                <argument name="logo_file" xsi:type="string">images/logo.svg</argument>
                <argument name="logo_img_width" xsi:type="number">200</argument>
                <argument name="logo_img_height" xsi:type="number">50</argument>
            </arguments>
        </referenceBlock>

        <!-- Free shipping banner above header -->
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="free.shipping.banner"
                   template="Magento_Theme::html/free-shipping-banner.phtml"
                   before="-"/>
        </referenceContainer>

        <!-- Footer custom links -->
        <referenceContainer name="footer">
            <block class="Magento\Cms\Block\Block" name="footer_links_custom" before="-">
                <arguments>
                    <argument name="block_id" xsi:type="string">footer_links_custom</argument>
                </arguments>
            </block>
        </referenceContainer>

        <!-- Copyright -->
        <referenceBlock name="copyright">
            <arguments>
                <argument name="copyright" xsi:type="string">© 2026 dopaliwa.pl — TECHTOR Jakub Cechowski. Wszelkie prawa zastrzeżone.</argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
