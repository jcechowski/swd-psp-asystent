<script>
(function () {
    var LS_KEY = 'dp_newsletter_popup_dismissed';
    var DELAY_MS = 30000;

    if (localStorage.getItem(LS_KEY)) return;

    function dismiss() {
        localStorage.setItem(LS_KEY, '1');
        document.getElementById('dp-newsletter-overlay').classList.remove('dp-nl-visible');
    }

    function showPopup() {
        var formKeyEl = document.querySelector('input[name=form_key]');
        if (formKeyEl) {
            document.getElementById('dp-nl-form-key').value = formKeyEl.value;
        }
        document.getElementById('dp-newsletter-overlay').classList.add('dp-nl-visible');
    }

    setTimeout(function () {
        showPopup();
    }, DELAY_MS);

    document.getElementById('dp-nl-close-btn').addEventListener('click', dismiss);

    document.getElementById('dp-newsletter-overlay').addEventListener('click', function (e) {
        if (e.target === this) dismiss();
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') dismiss();
    });

    document.getElementById('dp-nl-form').addEventListener('submit', function (e) {
        e.preventDefault();
        var email = document.getElementById('dp-nl-email').value.trim();
        if (!email) return;

        var formKey = document.getElementById('dp-nl-form-key').value;
        var body = new URLSearchParams();
        body.append('email', email);
        body.append('form_key', formKey);

        fetch('/newsletter/subscriber/new/', {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
            body: body.toString(),
            credentials: 'same-origin'
        }).finally(function () {
            document.getElementById('dp-nl-form').style.display = 'none';
            document.getElementById('dp-nl-success').style.display = 'block';
            localStorage.setItem(LS_KEY, '1');
            setTimeout(function () {
                document.getElementById('dp-newsletter-overlay').classList.remove('dp-nl-visible');
            }, 2500);
        });
    });
})();
</script>
