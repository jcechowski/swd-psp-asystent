<script>
(function() {
    var COOKIE_NAME = 'dp_cookie_consent';
    var consent = document.cookie.match('(^|;)\\s*' + COOKIE_NAME + '\\s*=\\s*([^;]+)');
    if (consent) return;

    var banner = document.getElementById('cookie-consent');
    if (!banner) return;
    banner.style.display = '';

    function setCookie(value) {
        var d = new Date();
        d.setFullYear(d.getFullYear() + 1);
        var secure = location.protocol === 'https:' ? ';Secure' : '';
        document.cookie = COOKIE_NAME + '=' + value + ';path=/;expires=' + d.toUTCString() + ';SameSite=Lax' + secure;
        banner.style.display = 'none';
    }

    document.getElementById('cookie-accept').addEventListener('click', function() {
        setCookie('all');
    });

    document.getElementById('cookie-reject').addEventListener('click', function() {
        setCookie('essential');
    });

    document.getElementById('cookie-settings-toggle').addEventListener('click', function() {
        var settings = document.getElementById('cookie-settings');
        settings.style.display = settings.style.display === 'none' ? '' : 'none';
    });

    document.getElementById('cookie-save').addEventListener('click', function() {
        var analytics = document.getElementById('cookie-analytics').checked;
        var marketing = document.getElementById('cookie-marketing').checked;
        var val = 'essential';
        if (analytics && marketing) val = 'all';
        else if (analytics) val = 'analytics';
        else if (marketing) val = 'marketing';
        setCookie(val);
    });
})();
</script>
