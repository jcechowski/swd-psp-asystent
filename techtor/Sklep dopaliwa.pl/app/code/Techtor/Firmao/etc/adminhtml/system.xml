<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="techtor_firmao" translate="label" sortOrder="20"
                 showInDefault="1" showInWebsite="0" showInStore="0">
            <label>Firmao ERP</label>
            <tab>techtor</tab>
            <resource>Techtor_Firmao::config</resource>
            <group id="general" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Ustawienia API</label>
                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Wlacz synchronizacje</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="api_url" translate="label" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>URL API Firmao</label>
                    <comment>np. https://system.firmao.pl/techtor</comment>
                </field>
                <field id="login" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Login</label>
                </field>
                <field id="password" translate="label" type="obscure" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Haslo</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>
            <group id="stock" translate="label" sortOrder="20"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Synchronizacja stanow</label>
                <field id="sync_enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Synchronizuj stany magazynowe</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
