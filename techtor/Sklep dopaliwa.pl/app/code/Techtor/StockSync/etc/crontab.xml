<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <!-- Glowna synchronizacja stanow: Firmao + Tarnawa → Magento — codziennie 6:00 -->
        <job name="techtor_stocksync_main"
             instance="Techtor\StockSync\Cron\MainSync"
             method="execute">
            <schedule>0 6 * * *</schedule>
        </job>
    </group>
</config>
